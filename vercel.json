{
  "version": 2,
  "builds": [
    { "src": "api/badge.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" },
    { "src": "sample_svgs/**", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/api/badge",
      "dest": "/api/badge.js",
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    },
    { "handle": "filesystem" }
  ]
}
